#include <iostream>
#include <vector>
using namespace std;

class Stack
{
    vector<int> v;

public:
    void push(int value)
    {
        v.push_back(value);
        cout << "The pushed value is :" << value << endl;
    }

    void pop()
    {
        if (v.empty())
        {
            cout << "The stake empty :" << endl;
            return;
        }

        cout << "The poped value is :" << v.back() << endl; // first print
        v.pop_back();                                       // then deleate
    }

    int top()
    {
        if (v.empty())
        {
            cout << "Stack is empty\n";
            return -1;
        }

        return v.back();
    }
    void display()
    {

        if (v.empty())
        {
            cout << "Stack is empty :";
            return;
        }

        cout << " Stack (top to bottom):" << endl;

        for (int i = (int)v.size() - 1; i >= 0; i--)
        {
            cout << v[i] << " ";
        }

        cout << endl;
    }
    // Check empty
    bool empty()
    {
        return v.empty();
    }
};

int main()
{

    Stack s;

    int choice, value;

    do
    {
        cout << "_____STACK MENU_____" << endl;
        cout << "1.Push" << endl;
        cout << "2.Pop" << endl;
        cout << "3.top" << endl;
        cout << "4.Display" << endl;
        cout << "5.Exist" << endl;
        cout << "Enter your choice: " << endl;

        cin >> choice;

        switch (choice)
        {
        case 1:
            cout << "Enter value: ";
            cin >> value;
            s.push(value);
            break;

        case 2:
            s.pop();
            break;

        case 3:
            cout << "Top element: " << s.top() << endl;
            break;

        case 4:
            s.display();
            break;

        case 5:
            cout << "Exiting...\n";
            break;
        default:
            cout << "Invalid choice\n";
        }
    } while (choice != 5);

    return 0;
}
