#include <iostream>
#include <stack>
using namespace std;

int main()
{
    stack<int> s;
    int n, value;

    cout << "Enter number of elements: "<<endl;
    cin >> n;

    cout << "Enter elements:"<<endl;
    for (int i = 0; i < n; i++)
    {
        cin >> value;
        s.push(value);   // push into stack
    }

    cout << "Stack (top to bottom): "<<endl;

    while (!s.empty())
    {
        cout << s.top() << " ";
        s.pop();
    }

    cout << endl;
    return 0;
}
