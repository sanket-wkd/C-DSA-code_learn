#include<iostream>
using namespace std;

// Pass by reference using alias
/*& in reference ≠ pointer
and "&" does not have any connection with memory*/


void changeA (int &b){
    b = 20;
    cout <<"Inside function: "<<b<<endl;
}

int main(){


    int a=10;
    changeA(a);
    cout << "Inside main: " << a<< endl;


    return 0;
}
