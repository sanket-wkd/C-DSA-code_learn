//code-1
//Normal code for pointer 

#include <iostream>
using namespace std;

int main()
{
    int a = 10;
    int *p = &a; // assign pointer to to store address
    // *p correct p* wrong

    cout << "The value of a :" << a << endl;//10
    cout << "The Address of a :" << &a << endl;//0x61ff08
    cout << "Pointer p stores :" << p << endl;//0x61ff08
    cout << "Value in pointer p :" << a << endl;//10

    return 0;
}

//code-2
//Arrey pointers single element access

#include <iostream>
using namespace std;

int main()
{
    int arr[3] = {10, 20, 30};
    int *p = arr; // assing pointer to constant pointer

    cout << *p << endl;       // 10
    cout << *(p + 1) << endl; // 20
    cout << *(p + 2) << endl; // 30
    cout << *(p + 3);         // garbage value

    return 0;
}

//code -3
//pointer Arrey complete access

#include <iostream>
using namespace std;

int main()
{
    int arr[3] = {100, 200, 300};
    int (*p)[3] = &arr; // points toward hole pointer

    cout << (*p)[0] << endl; // 100
    cout << (*p)[1] << endl; // 200
    cout << (*p)[2] << endl; // 300
    cout << (*p)[3] << endl; // garbage value

    return 0;
}
